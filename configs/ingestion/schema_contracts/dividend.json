{
  "endpoint": "dividend",
  "version": "v0",
  "description": "分红送股",
  "business_fields": {
    "primary_key": ["ts_code", "end_date", "ann_date", "ex_date", "record_date", "pay_date", "div_proc"],
    "date_fields": ["end_date", "ann_date", "record_date", "ex_date", "pay_date", "div_listdate", "imp_ann_date", "base_date"],
    "numeric_fields": ["stk_div", "stk_bo_rate", "stk_co_rate", "cash_div", "cash_div_tax", "base_share"],
    "string_fields": ["ts_code", "div_proc"]
  },
  "fields": [
    {"name": "ts_code", "type": "STRING", "nullable": false, "description": "TS代码"},
    {"name": "end_date", "type": "STRING", "nullable": true, "description": "分红年度 YYYYMMDD"},
    {"name": "ann_date", "type": "STRING", "nullable": true, "description": "预案公告日 YYYYMMDD"},
    {"name": "div_proc", "type": "STRING", "nullable": true, "description": "实施进度"},
    {"name": "stk_div", "type": "FLOAT", "nullable": true, "description": "每股送转"},
    {"name": "stk_bo_rate", "type": "FLOAT", "nullable": true, "description": "每股送股比例"},
    {"name": "stk_co_rate", "type": "FLOAT", "nullable": true, "description": "每股转增比例"},
    {"name": "cash_div", "type": "FLOAT", "nullable": true, "description": "每股分红（税后）"},
    {"name": "cash_div_tax", "type": "FLOAT", "nullable": true, "description": "每股分红（税前）"},
    {"name": "record_date", "type": "STRING", "nullable": true, "description": "股权登记日 YYYYMMDD"},
    {"name": "ex_date", "type": "STRING", "nullable": true, "description": "除权除息日 YYYYMMDD"},
    {"name": "pay_date", "type": "STRING", "nullable": true, "description": "派息日 YYYYMMDD"},
    {"name": "div_listdate", "type": "STRING", "nullable": true, "description": "红股上市日 YYYYMMDD"},
    {"name": "imp_ann_date", "type": "STRING", "nullable": true, "description": "实施公告日 YYYYMMDD"},
    {"name": "base_date", "type": "STRING", "nullable": true, "description": "基准日 YYYYMMDD"},
    {"name": "base_share", "type": "FLOAT", "nullable": true, "description": "基准股本（万股）"}
  ]
}
