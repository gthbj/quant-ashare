{
  "endpoint": "index_daily",
  "version": "v0",
  "description": "指数日频行情",
  "business_fields": {
    "primary_key": ["ts_code", "trade_date"],
    "date_fields": ["trade_date"],
    "numeric_fields": ["close", "open", "high", "low", "pre_close", "change", "pct_chg", "vol", "amount"],
    "string_fields": ["ts_code"]
  },
  "fields": [
    {"name": "ts_code", "type": "STRING", "nullable": false, "description": "TS指数代码"},
    {"name": "trade_date", "type": "STRING", "nullable": false, "description": "交易日期 YYYYMMDD"},
    {"name": "close", "type": "FLOAT", "nullable": true, "description": "收盘点位"},
    {"name": "open", "type": "FLOAT", "nullable": true, "description": "开盘点位"},
    {"name": "high", "type": "FLOAT", "nullable": true, "description": "最高点位"},
    {"name": "low", "type": "FLOAT", "nullable": true, "description": "最低点位"},
    {"name": "pre_close", "type": "FLOAT", "nullable": true, "description": "昨收点位"},
    {"name": "change", "type": "FLOAT", "nullable": true, "description": "涨跌点数"},
    {"name": "pct_chg", "type": "FLOAT", "nullable": true, "description": "涨跌幅（%）"},
    {"name": "vol", "type": "FLOAT", "nullable": true, "description": "成交量（手）"},
    {"name": "amount", "type": "FLOAT", "nullable": true, "description": "成交额（千元）"}
  ]
}
