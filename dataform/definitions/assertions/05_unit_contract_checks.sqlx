config {
  type: "operations",
  name: "unit_contract_checks",
  tags: ["qa_contract"],
  dependencies: ["ods_field_unit_map", "dwd_stock_eod_price", "dwd_stock_eod_valuation", "dwd_stock_dividend_event", "dwd_index_eod", "dwd_fin_indicator", "dwd_fin_income", "dwd_fin_balancesheet", "dwd_fin_cashflow"]
