FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates fontconfig fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/*

COPY scripts/strategy1/requirements.txt /tmp/requirements.txt
RUN pip install -r /tmp/requirements.txt

COPY . /app

CMD ["python", "-m", "scripts.strategy1_cloudrun.orchestrate_experiments", "--help"]
